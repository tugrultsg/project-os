{
  "version": "0.1.0",
  "lastReviewed": "{{CURRENT_DATE}}",
  "googleAnalytics4": {
    "requiredForPublicWeb": true,
    "measurementId": "{{GA4_MEASUREMENT_ID}}",
    "propertyId": "{{GA4_PROPERTY_ID}}",
    "consentModeRequired": true,
    "piiCollectionAllowed": false,
    "debugModeAllowedOutsideProduction": true,
    "serviceAccountSecretName": "{{GA4_SERVICE_ACCOUNT_SECRET_NAME}}",
    "environments": {
      "production": {
        "measurementId": "{{GA4_PRODUCTION_MEASUREMENT_ID}}",
        "propertyId": "{{GA4_PRODUCTION_PROPERTY_ID}}"
      },
      "staging": {
        "measurementId": "{{GA4_STAGING_MEASUREMENT_ID}}",
        "propertyId": "{{GA4_STAGING_PROPERTY_ID}}"
      }
    }
  },
  "googleSearchConsole": {
    "requiredForPublicWeb": true,
    "propertyType": "{{GSC_PROPERTY_TYPE}}",
    "propertyUrl": "{{PRIMARY_DOMAIN}}",
    "verificationMethod": "{{GSC_VERIFICATION_METHOD}}",
    "sitemapSubmissionRequired": true,
    "urlInspectionApiOptional": true,
    "serviceAccountSecretName": "{{GSC_SERVICE_ACCOUNT_SECRET_NAME}}"
  },
  "events": {
    "pageViewRequired": true,
    "conversionEventsDecisionRequiredBeforePublicLaunch": true,
    "recommendedEvents": ["sign_up", "login", "generate_lead", "purchase", "subscribe"],
    "eventsMustAvoidPii": true,
    "serverSideEventsRequireDeduplication": true
  },
  "launchGates": {
    "ga4InstalledBeforePublicLaunch": true,
    "gscVerifiedBeforePublicLaunch": true,
    "sitemapSubmittedBeforePublicLaunch": true,
    "robotsCheckedBeforePublicLaunch": true,
    "productionUsesDedicatedGa4Property": true
  },
  "monitoring": {
    "postDeployTrafficCheckRequired": true,
    "organicSearchPerformanceCheckCadence": "weekly",
    "sitemapCoverageCheckCadence": "weekly",
    "conversionTrackingSmokeTestRequired": true
  }
}
