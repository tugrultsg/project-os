    "twitterCardRequired": true,
    "metaKeywordsRankingDependencyAllowed": false
  },
  "indexability": {
    "newPublicPageRequiresIndexIntent": true,
    "newDynamicRouteRequiresSitemapDecision": true,
    "changedUrlRequiresRedirectDecision": true,
    "sitemapLastModifiedMustReflectContentChange": true
  },
  "structuredData": {
