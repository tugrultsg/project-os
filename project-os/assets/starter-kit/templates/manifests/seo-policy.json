    "escapeJsonLdLessThan": true,
    "faqPageForGoogleRichResultsAllowedFor": ["government", "healthcare"],
    "faqPageOnCommercialSites": "allowed only for content structure or AI citation readiness, not as a Google rich-result promise",
    "howToSchemaRecommended": false
  },
  "images": {
    "altTextRequiredForInformativeImages": true,
    "decorativeImagesMustBeHidden": true,
    "ogImagesShouldBePageSpecific": true,
    "belowFoldImagesShouldLazyLoad": true,
    "dimensionsRequiredToAvoidCls": true
  },
  "aiSearchReadiness": {
    "brandEntityClear": true,
    "crawlableTextRequired": true,
    "llmsTxtDecisionRequiredForGeneratedSites": true,
