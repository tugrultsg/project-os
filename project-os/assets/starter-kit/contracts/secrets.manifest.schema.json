{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-os.local/contracts/secrets.manifest.schema.json",
  "title": "Secrets Manifest",
  "type": "object",
  "required": ["version", "lastReviewed", "policy", "secrets"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "lastReviewed": { "type": "string", "minLength": 1 },
    "policy": {
      "type": "object",
      "required": ["valuesAllowed", "sourceOfTruth"],
      "properties": {
        "valuesAllowed": { "const": false },
        "sourceOfTruth": { "type": "string", "minLength": 1 },
        "workerRequiredSecretsAlsoLiveIn": { "type": "string" }
      }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "required", "destinations", "owner"],
        "not": { "required": ["value"] },
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "required": { "type": "boolean" },
          "destinations": { "type": "array", "items": { "type": "string" } },
          "owner": { "type": "string", "minLength": 1 },
          "rotation": { "type": "string" }
        }
      }
    }
  }
}

