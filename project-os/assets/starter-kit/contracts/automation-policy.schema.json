{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-os.local/contracts/automation-policy.schema.json",
  "title": "Automation Policy",
  "type": "object",
  "required": ["version", "lastReviewed", "defaultLanes", "nonDefaultLanes", "rules"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "lastReviewed": { "type": "string", "minLength": 1 },
    "defaultLanes": { "type": "object" },
    "nonDefaultLanes": { "type": "object" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}

